{
  "display_information": {
    "name": "<<APP_NAME>>",
    "description": "<<FILL-IN: one-line description of your war-room agent>>",
    "background_color": "#1a1a1a"
  },
  "features": {
    "bot_user": {
      "display_name": "<<BOT_HANDLE>>",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/ping",
        "description": "Health check - the bot replies pong",
        "usage_hint": "",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "chat:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
